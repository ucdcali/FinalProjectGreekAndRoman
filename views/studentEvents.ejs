<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <title>studentEvents</title>
</head>
<body>
    <main>
     <a href="/">Back to Student Page</a>
    <h2>Current Events</h2>

    <ul class="event-list">
        <% if (events && events.length > 0) { %>
            <% events.forEach(event => { %>
            <li class="event-item">
                <strong><%= event.name %></strong> — <%= event.message %>
                <em>(<%= event.date %>)</em>
            </li>
            <% }) %>
        <% } else { %>
            <li class="no-events-message">No events currently!</li>
        <% } %>
    </ul>
    </main>
</body>
</html>

