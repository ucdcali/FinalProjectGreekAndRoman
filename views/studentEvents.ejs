<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <title>eventsStudent</title>
</head>
<body>
    <ul class="event-list">
    <% events.forEach(event => { %>
        <li class="event-item">
            <strong><%= event.name %></strong> — <%= event.message %>
            <em>(<%= event.date %>)</em>
        </li>
    <% }) %>
</ul>

</body>
</html>